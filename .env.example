# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=financedb
POSTGRES_USER=finance
POSTGRES_PASSWORD=changeme

# Constructed by docker-compose; override here only if running backend locally.
# DATABASE_URL=postgresql+asyncpg://finance:changeme@localhost:5432/financedb

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret

JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# Bootstrap admin — used only on first run when users table is empty.
# Safe to remove from .env after first boot.
ADMIN_EMAIL=admin@finance.internal
ADMIN_PASSWORD=changeme_first_run_only

# ── IMAP ──────────────────────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_MINUTES=5

# Directory where raw .eml files are stored (must match the Docker volume mount).
# Default matches docker-compose.yml — only change if you override the volume.
RAW_EMAIL_DIR=/data/raw_emails

# ── AI Provider (claude | gemini | lmstudio) ──────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=
CLAUDE_API_KEY=
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=
